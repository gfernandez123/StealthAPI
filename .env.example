# --- Database ---
# Local dev: `npx prisma dev` (runs Postgres locally) or point at Neon/Supabase.
DATABASE_URL="postgresql://user:password@localhost:5432/stealthapi?schema=public"

# --- App secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=""
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OAUTH_STATE_SECRET=""

# --- QuickBooks Online ---
# Create an app at https://developer.intuit.com/app/developer/dashboard
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/api/connect/quickbooks/callback"
QBO_ENVIRONMENT="sandbox" # sandbox | production

# --- Xero ---
# Create an app at https://developer.xero.com/app/manage
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3000/api/connect/xero/callback"

# --- Plaid ---
# Get sandbox credentials at https://dashboard.plaid.com
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox" # sandbox | development | production
PLAID_WEBHOOK_URL=""
